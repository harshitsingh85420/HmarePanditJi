# PRE-PUSH GATE — mechanical, and it gates EVERY pusher including the agent
# (2026-07-23). First version used `pnpm` directly; the agent's shell has no
# pnpm (and no node on PATH), so it fell back to `git push --no-verify` — i.e.
# the gate protected the human who rarely pushes and exempted the agent who
# pushes constantly. This version RESOLVES the toolchain robustly (pnpm on PATH
# → corepack → local .bin → and a direct-node fallback that needs no package
# manager at all), so it runs in a normal shell AND the agent's environment.
#
# What it does: tsc across ALL workspaces always; `next build` only for apps
# whose files changed (a shared packages/ change → all three). Measured ~37s
# typical, ~82s worst — under the 90s bar, so it BLOCKS. Real escape hatch:
# `git push --no-verify` (should be rare and deliberate, never routine).

# ── resolve a node binary: PATH, then known absolute installs ────────────────
resolve_node() {
  if command -v node >/dev/null 2>&1; then command -v node; return 0; fi
  for c in \
    "/c/Program Files/AutoClaw/resources/node/node.exe" \
    "/c/Program Files/nodejs/node.exe" \
    "/usr/bin/node" "/usr/local/bin/node"; do
    [ -x "$c" ] && { printf '%s\n' "$c"; return 0; }
  done
  return 1
}

# ── resolve a pnpm runner (prints the command prefix), else empty ────────────
resolve_pnpm() {
  if command -v pnpm >/dev/null 2>&1; then echo "pnpm"; return 0; fi
  if command -v corepack >/dev/null 2>&1; then echo "corepack pnpm"; return 0; fi
  [ -x "node_modules/.bin/pnpm" ] && { echo "node_modules/.bin/pnpm"; return 0; }
  echo ""
}

NODE="$(resolve_node || true)"
PNPM="$(resolve_pnpm)"

if [ -z "$PNPM" ] && [ -z "$NODE" ]; then
  echo "✗ pre-push gate: neither pnpm nor node found in this environment."
  echo "  Refusing to pass silently. Install node/pnpm, or 'git push --no-verify' to override deliberately."
  exit 1
fi
echo "▶ pre-push gate: toolchain = ${PNPM:-direct-node ($NODE)}"

# ── run helpers (pnpm when present, else direct per-workspace node) ───────────
BUILD_ENV_URL="http://localhost:3001/api/v1"

run_tsc_all() {
  if [ -n "$PNPM" ]; then $PNPM ts:check:all; return $?; fi
  for w in apps/pandit apps/admin apps/web services/api; do
    echo "  tsc: $w"
    ( cd "$w" && "$NODE" ./node_modules/typescript/bin/tsc --noEmit ) || return 1
  done
}

run_build() { # $1 = pandit|admin|web
  echo "▶ next build: $1 (its files changed)…"
  if [ -n "$PNPM" ]; then
    NEXT_PUBLIC_API_URL="$BUILD_ENV_URL" NODE_ENV=production $PNPM --filter "@hmarepanditji/$1" build
    return $?
  fi
  ( cd "apps/$1" && NEXT_PUBLIC_API_URL="$BUILD_ENV_URL" NODE_ENV=production "$NODE" ./node_modules/next/dist/bin/next build )
}

# ── which commits are being pushed → changed files ───────────────────────────
read _lref _lsha _rref rsha || true
if [ -z "$rsha" ] || [ "$(echo "$rsha" | tr -d 0)" = "" ]; then
  base=$(git merge-base HEAD origin/main 2>/dev/null || echo "")
else
  base="$rsha"
fi
[ -z "$base" ] && base=$(git rev-parse HEAD~1 2>/dev/null || echo HEAD)
changed=$(git diff --name-only "$base" HEAD 2>/dev/null || echo "")

echo "▶ tsc, all workspaces (range ${base}..HEAD)…"
run_tsc_all || { echo "✗ tsc failed — push blocked. Fix, or 'git push --no-verify' to override."; exit 1; }

if echo "$changed" | grep -q '^packages/'; then
  echo "  shared packages/ changed → building all apps"
  run_build pandit || exit 1
  run_build admin  || exit 1
  run_build web    || exit 1
else
  if echo "$changed" | grep -q '^apps/pandit/'; then run_build pandit || exit 1; fi
  if echo "$changed" | grep -q '^apps/admin/';  then run_build admin  || exit 1; fi
  if echo "$changed" | grep -q '^apps/web/';    then run_build web    || exit 1; fi
fi

echo "✓ pre-push gate passed"
exit 0
