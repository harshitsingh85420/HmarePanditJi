# Sarvam AI Configuration
# Get your API key from: https://dashboard.sarvam.ai
# Apply for startup program: https://sarvam.ai/startup

# Server-side API key (never exposed to browser)
SARVAM_API_KEY=your_sarvam_api_key_here

# Client-side API key (for WebSocket connections)
NEXT_PUBLIC_SARVAM_API_KEY=your_sarvam_api_key_here

# Environment
NEXT_PUBLIC_APP_ENV=development

# Optional: Deepgram API key (for fallback)
# DEEPGRAM_API_KEY=your_deepgram_api_key_here

# Optional: Enable detailed voice logging
NEXT_PUBLIC_VOICE_LOGGING=true
