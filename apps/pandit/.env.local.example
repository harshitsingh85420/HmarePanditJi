# ============================================================
# HmarePanditJi — Local Environment Variables (Pandit App)
# Copy this file to .env.local and fill in real values
# NEVER commit .env.local to git
# ============================================================

# ===== SARVAM AI (Voice Engine - Indian Languages) =====
# Get API key from dashboard.sarvam.ai
# Apply for startup program at sarvam.ai/startup
SARVAM_API_KEY=your_sarvam_api_key_here

# ===== REDIS (Optional - for production caching) =====
# If not set, in-memory caching will be used
REDIS_URL=redis://localhost:6379

# ===== NODE ENV =====
NODE_ENV=development
