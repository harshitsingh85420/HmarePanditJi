# ===== services/api =====
DATABASE_URL="postgresql://user:password@host:5432/hmarepanditji"  # Neon connection string
REDIS_URL="rediss://default:password@host:6379"                     # Upstash Redis URL
JWT_SECRET="change-me-64-random-chars"                              # generate: openssl rand -hex 32
OTP_DEV_MODE="true"                                                 # true = OTP is always 123456 (pilot); set false for real SMS
DEEPGRAM_API_KEY="dg_xxxxxxxx"                                      # speech-to-text
SARVAM_API_KEY="sv_xxxxxxxx"                                        # text-to-speech
SARVAM_TTS_SPEAKER="aditya"                                         # male speaker for Shishya persona (bulbul:v3); verify with: node scripts/check-sarvam-speaker.mjs
ADMIN_EMAIL="admin@hmarepanditji.com"
ADMIN_PASSWORD_HASH="$2b$10$xxxxxxxxxxxxxxxxxxxxxx"                 # bcrypt hash; generate with: node -e "console.log(require('bcryptjs').hashSync('yourpassword',10))"
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001,http://localhost:3002"  # comma-separated; add Vercel URLs after deploy
PORT="8080"

# ===== apps/pandit, apps/admin, apps/web =====
NEXT_PUBLIC_API_URL="http://localhost:8080"                         # ORIGIN only — the client appends /api/v1 itself; set to Render URL in Vercel dashboard
NEXT_PUBLIC_OTP_DEV_MODE="true"                                     # mirror of OTP_DEV_MODE for the pandit app (skips the WebOTP guidance line when no real SMS arrives); set false in Vercel when MSG91 goes live

# ── Voice pace (D4) ─────────────────────────────────────────
# Sarvam TTS speaking pace for the pandit app (0.5–2.0). 1.15 = brisk
# but clear for elderly Hindi listeners. Set on Vercel (pandit app) too.
SARVAM_TTS_PACE=1.15
SHISHYA_LLM_MODEL="sarvam-30b"                                        # T4: Sarvam chat model for the Shishya agent (valid 2026-07: sarvam-30b, sarvam-105b — a 4xx names current ones)
