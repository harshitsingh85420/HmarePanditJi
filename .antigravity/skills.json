{
  "name": "hmarepanditji-visual-testing",
  "version": "1.0.0",
  "description": "Visual browser testing skills for Antigravity Agent with DeepSeek AI integration",
  "skills": [
    {
      "id": "deepseek-code-agent",
      "name": "DeepSeek AI Coding Agent",
      "description": "Use DeepSeek-V3 (latest model) as AI coding assistant for code generation, debugging, and refactoring",
      "trigger": [
        "deepseek",
        "generate code",
        "fix this",
        "create component",
        "add feature",
        "refactor",
        "debug"
      ],
      "actions": [
        {
          "type": "api",
          "endpoint": "https://api.deepseek.com/chat/completions",
          "method": "POST",
          "headers": {
            "Authorization": "Bearer sk-8ff9a856f5ea4c638fcd715c65655218",
            "Content-Type": "application/json"
          },
          "body": {
            "model": "deepseek-chat",
            "messages": [
              {
                "role": "system",
                "content": "You are an expert Next.js 14, React, and TypeScript developer. You help build HmarePanditJi - a Hindu pandit booking platform. Write clean, production-ready code."
              },
              {
                "role": "user",
                "content": "{{USER_PROMPT}}"
              }
            ],
            "temperature": 0.7,
            "max_tokens": 2048
          },
          "output": {
            "extract": "choices[0].message.content",
            "saveTo": "test-results/deepseek-response.md"
          }
        }
      ],
      "output": {
        "type": "markdown",
        "template": "Generated code and suggestions saved to test-results/deepseek-response.md"
      }
    },
    {
      "id": "visual-test",
      "name": "Visual Test Runner",
      "description": "Run visual browser tests with screenshot capture and regression detection",
      "trigger": [
        "visual test",
        "screenshot test",
        "browser test",
        "UI test",
        "visual regression"
      ],
      "actions": [
        {
          "type": "script",
          "command": "node scripts/visual-test.js --url {{URL}} --regression",
          "env": {
            "URL": "http://localhost:3000"
          }
        },
        {
          "type": "browser",
          "action": "captureScreenshot",
          "saveTo": "test-results/visual/"
        },
        {
          "type": "browser",
          "action": "captureDOM",
          "saveTo": "test-results/visual/dom-state.json"
        },
        {
          "type": "browser",
          "action": "recordSession",
          "saveTo": "test-results/visual/session-recording.webm"
        }
      ],
      "output": {
        "type": "markdown",
        "template": "test-results/visual-report.md"
      }
    },
    {
      "id": "ui-interaction",
      "name": "UI Interaction Tester",
      "description": "Test UI interactions like click, type, navigate",
      "trigger": [
        "test UI",
        "interaction test",
        "click test",
        "form test"
      ],
      "actions": [
        {
          "type": "browser",
          "action": "navigate",
          "url": "{{URL}}"
        },
        {
          "type": "browser",
          "action": "waitForSelector",
          "selector": "{{SELECTOR}}"
        },
        {
          "type": "browser",
          "action": "click",
          "selector": "{{SELECTOR}}"
        },
        {
          "type": "browser",
          "action": "screenshot",
          "saveTo": "test-results/visual/interaction-{timestamp}.png"
        }
      ]
    },
    {
      "id": "visual-comparison",
      "name": "Visual Regression Check",
      "description": "Compare current UI with baseline for regression detection",
      "trigger": [
        "regression check",
        "compare UI",
        "visual diff",
        "baseline check"
      ],
      "actions": [
        {
          "type": "script",
          "command": "node scripts/visual-test.js --regression --baseline test-results/baseline/"
        },
        {
          "type": "browser",
          "action": "captureScreenshot",
          "saveTo": "test-results/visual/current/"
        },
        {
          "type": "comparison",
          "baseline": "test-results/baseline/",
          "current": "test-results/visual/current/",
          "threshold": 5,
          "output": "test-results/visual/regression-report.json"
        }
      ]
    },
    {
      "id": "dom-analysis",
      "name": "DOM Structure Analyzer",
      "description": "Analyze DOM structure, elements, and accessibility",
      "trigger": [
        "analyze DOM",
        "DOM check",
        "accessibility",
        "element count"
      ],
      "actions": [
        {
          "type": "browser",
          "action": "captureDOM",
          "options": {
            "includeAccessibility": true,
            "includeAria": true,
            "includeSemantic": true
          },
          "saveTo": "test-results/visual/dom-analysis.json"
        },
        {
          "type": "browser",
          "action": "evaluate",
          "code": "document.querySelectorAll('*').length"
        },
        {
          "type": "browser",
          "action": "evaluate",
          "code": "document.querySelectorAll('[aria-label]').length"
        },
        {
          "type": "browser",
          "action": "evaluate",
          "code": "document.querySelectorAll('button, a, input').length"
        }
      ]
    },
    {
      "id": "performance-snapshot",
      "name": "Performance & Visual Metrics",
      "description": "Capture performance metrics alongside visual state",
      "trigger": [
        "performance test",
        "load time",
        "visual metrics",
        "core web vitals"
      ],
      "actions": [
        {
          "type": "browser",
          "action": "captureMetrics",
          "metrics": [
            "first-contentful-paint",
            "largest-contentful-paint",
            "cumulative-layout-shift",
            "time-to-interactive"
          ],
          "saveTo": "test-results/visual/performance.json"
        },
        {
          "type": "browser",
          "action": "screenshot",
          "saveTo": "test-results/visual/performance-snapshot.png"
        }
      ]
    }
  ],
  "workflows": [
    {
      "id": "full-visual-test",
      "name": "Complete Visual Test Suite",
      "description": "Run full visual testing workflow",
      "steps": [
        {
          "skill": "visual-test",
          "params": {
            "url": "http://localhost:3000"
          }
        },
        {
          "skill": "ui-interaction",
          "params": {
            "url": "http://localhost:3000",
            "selector": "button"
          }
        },
        {
          "skill": "dom-analysis"
        },
        {
          "skill": "visual-comparison"
        },
        {
          "skill": "performance-snapshot"
        },
        {
          "type": "report",
          "template": "test-results/visual/combined-report.md",
          "notify": "qwen-code"
        }
      ]
    }
  ],
  "antigravity": {
    "browserSubagent": {
      "enabled": true,
      "model": "gemini-2.5-vision",
      "capabilities": [
        "screenshot",
        "domCapture",
        "interaction",
        "recording",
        "visualRegression"
      ]
    },
    "artifacts": {
      "enabled": true,
      "types": [
        "screenshots",
        "recordings",
        "domState",
        "reports"
      ]
    },
    "mcp": {
      "enabled": true,
      "servers": [
        {
          "name": "browser-mcp",
          "command": "npx -y @antigravity/browser-mcp"
        }
      ]
    }
  }
}